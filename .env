# ═══════════════════════════════════════════════════════════════
# CatalystX Environment Variables Template
# Copy this file to .env in both frontend and backend directories
# Fill in your actual values
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# FRONTEND (.env in Vite project root)
# ─────────────────────────────────────────────────────────────

# API Base URL - Backend server address
# Development: Local backend server
# Production: Your deployed backend URL
VITE_API_BASE_URL=http://localhost:4000

# Optional: API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Optional: Environment name
VITE_ENV=development

# ─────────────────────────────────────────────────────────────
# BACKEND (.env in Node.js server root)
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas Connection String
# Get this from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
# 
# Steps to get your URI:
# 1. Create MongoDB Atlas account
# 2. Create a cluster
# 3. Create database user (remember the password!)
# 4. Click "Connect" → "Drivers" → Copy the connection string
# 5. Replace <password> with your actual password
# 6. Replace "myFirstDatabase" with "catalystx"
MONGODB_URI=mongodb+srv://aimenfatima075_db_user:GqFRjMe50mdW5xMC@cluster0.khqcotg.mongodb.net/catalystx?retryWrites=true&w=majority

# JWT Secret - Generate a strong random string
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT: Change this in production! Never commit the actual secret!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_123456

# Server Port
PORT=4000

# Node Environment
# Values: development | production | staging
NODE_ENV=development

# Optional: Log Level
# Values: error | warn | info | debug
LOG_LEVEL=info

# CORS Settings
# Comma-separated list of allowed origins
# Development: localhost:5173 (Vite default)
# Production: your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Email Service (for future use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ─────────────────────────────────────────────────────────────
# PRODUCTION SETTINGS (Update when deploying)
# ─────────────────────────────────────────────────────────────

# Frontend Production (.env.production)
# VITE_API_BASE_URL=https://api.yourdomain.com

# Backend Production (.env)
# NODE_ENV=production
# JWT_SECRET=generate-a-new-strong-secret
# CORS_ORIGINS=https://yourdomain.com

# ─────────────────────────────────────────────────────────────
# MONGODB ATLAS SETUP STEPS
# ─────────────────────────────────────────────────────────────

# 1. Create Account: https://www.mongodb.com/cloud/atlas
# 2. Create Project: Name it "CatalystX"
# 3. Create Cluster:
#    - Choose M0 Free Tier
#    - Select your region
#    - Wait for deployment (~10 min)
# 4. Create Database User:
#    - Go to Security > Database Access
#    - Add New Database User
#    - Username: catalystx_user
#    - Password: Generate strong password (save it!)
#    - Role: Read and write to any database
# 5. Get Connection String:
#    - Go to Clusters > Connect
#    - Click "Drivers"
#    - Select "Node.js" (latest version)
#    - Copy connection string
#    - Replace <password> with actual password
#    - Replace "myFirstDatabase" with "catalystx"
# 6. Update this file with your connection string

# ─────────────────────────────────────────────────────────────
# JWT SECRET GENERATION
# ─────────────────────────────────────────────────────────────

# Run this in Node.js to generate a secure random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Output will be something like:
# a7f9c2e8d4b1f6a9e2c5d8f1a4b7c0e3f6a9c2d5e8f1a4b7c0e3f6a9c2d5

# ─────────────────────────────────────────────────────────────
# SECURITY NOTES
# ─────────────────────────────────────────────────────────────

# ⚠️  NEVER commit .env files to git!
# ✅ Always use .gitignore to exclude .env

# Add to .gitignore:
# .env
# .env.local
# .env.*.local

# For production:
# - Use platform-specific secrets (Vercel, Heroku, etc.)
# - Rotate JWT secret regularly
# - Use strong, unique passwords
# - Enable MongoDB Atlas IP whitelist
# - Use HTTPS everywhere
# - Set secure CORS origins

# ─────────────────────────────────────────────────────────────
# TESTING CREDENTIALS
# ─────────────────────────────────────────────────────────────

# Use these to test your setup after deployment:
# 
# Email: test@catalystx.com
# Password: TestPassword123
#
# Or create your own test account by registering through the app

# ─────────────────────────────────────────────────────────────
# TROUBLESHOOTING
# ─────────────────────────────────────────────────────────────

# If MongoDB connection fails:
# 1. Check MongoDB Atlas is running (green status)
# 2. Verify password is correct (no special chars except !@#$%^&*)
# 3. Add your IP to MongoDB Atlas whitelist:
#    - Security > Network Access > Add IP Address
#    - For development: 0.0.0.0/0 (allow all)
#    - For production: Add specific IPs only

# If API calls fail:
# 1. Check frontend VITE_API_BASE_URL matches backend PORT
# 2. Verify backend is running: curl http://localhost:4000/health
# 3. Check CORS is configured correctly
# 4. Check browser console for error messages

# If JWT verification fails:
# 1. Ensure JWT_SECRET is the same on backend
# 2. Check token isn't expired
# 3. Verify Authorization header format: "Bearer TOKEN"
